# data — contains PLAINTEXT prompts/outputs; never commit
/data/*
!/data/.gitkeep

# Go
/assay
/bin/
*.test
*.out
coverage.*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/

# editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# web/ frontend (maintained separately) — never commit its deps/build/secrets
# even if added from the repo root. The frontend's own .gitignore also covers these.
web/node_modules/
web/.next/
web/out/
web/build/
**/.env
**/.env.*
!**/.env.example
