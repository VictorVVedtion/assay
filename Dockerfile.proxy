# assay data plane (Go) — transparent audit proxy
FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 go build -trimpath -o /out/assay ./cmd/assay

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/assay /usr/local/bin/assay
ENTRYPOINT ["assay"]
